{
  "manifest_version": 3,
  "name": "Auto Script Kuesioner SIMA",
  "version": "1.0.0",
  "description": "Otomatiskan respons kuesioner SIMA Unira dengan satu klik — by muchrid",
  "author": "muchrid",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Auto Script Kuesioner SIMA"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": []
}
